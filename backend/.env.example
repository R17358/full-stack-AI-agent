# ─── LLM Provider ────────────────────────────────────────────────────
# Choose one: google | openai | anthropic | ollama
LLM_PROVIDER=google

# Model for the chosen provider:
#   google:    gemini-2.5-flash | gemini-1.5-pro | gemini-1.5-flash
#   openai:    gpt-4o | gpt-4o-mini | gpt-3.5-turbo
#   anthropic: claude-sonnet-4-5 | claude-3-5-haiku-20241022
#   ollama:    llama3 | mistral | phi3
LLM_MODEL=gemini-2.5-flash

# ─── API Keys ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Tavily for web search (free tier at https://tavily.com)
TAVILY_API_KEY=your_tavily_key_here

# ─── Image Generation ─────────────────────────────────────────────────
# Leave empty to disable image generation
# Options: stability | openai | google
IMAGE_PROVIDER=

# Stability AI key (get free at https://platform.stability.ai)
STABILITY_API_KEY=

# ─── Embeddings (for RAG) ─────────────────────────────────────────────
# google (needs GOOGLE_API_KEY) | openai (needs OPENAI_API_KEY) | local (no key needed)
EMBEDDING_PROVIDER=google

# ─── Ollama (local models) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Agent Tuning ─────────────────────────────────────────────────────
AGENT_TEMPERATURE=0.7
AGENT_MAX_ITERATIONS=6
MEMORY_WINDOW_K=12
